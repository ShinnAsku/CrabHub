{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrabHub",
  "version": "0.1.0",
  "identifier": "com.crabhub.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "CrabHub",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost https://api.deepseek.com https://api.openai.com https://dashscope.aliyuncs.com http://localhost:11434"
    }
  },
  "plugins": {
    "security": {
      "secure-storage": {
        "all": true
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/CrabHub/crabhub/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4MUUzM0VDQjU2OTcwNEIKUldSTGNHbTE3RE1lNkRibEtFS0xydVJHWHpMRG50WUtUY0lVcG8zdHdUVHAwZWdiTS9NRmdKTGgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 CrabHub",
    "shortDescription": "A lightweight database management tool",
    "longDescription": "CrabHub is a lightweight, open-source database management tool with AI assistance. Supports PostgreSQL, MySQL, SQLite, GaussDB and more."
  }
}
